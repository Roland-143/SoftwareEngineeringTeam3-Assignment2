# Environment variables for the Course Management System
# Copy this file to .env and update values for your local machine.
# Commit .env.example, never commit .env with real secrets.

COMPOSE_PROJECT_NAME=course-project2

# Database bootstrap and app DB user
# Use unique local values, not defaults, in your real .env file.
MYSQL_ROOT_PASSWORD=replace_with_local_root_password
APP_DB_USER=studentapp
APP_DB_PASSWORD=replace_with_local_app_password
MYSQL_PORT=3306

# Active backend database name used by the current schema/init path.
# docker-compose.yml mounts 01_schema.sql / 02_data.sql and uses student_db.
DB_NAME=student_db

# Backend
APP_ENV=development
BACKEND_PORT=5000

# Frontend (still scaffold – update when frontend stack is finalized)
API_BASE_URL=http://localhost:5000

# Optional compose profiles:
# COMPOSE_PROFILES=scaffold
